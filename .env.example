# VnLaw-QA Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Crawler Configuration
# =============================================================================
CRAWLER_RATE_LIMIT_SECONDS=2.0
CRAWLER_MAX_CONCURRENCY=2
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT_SECONDS=60

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# API Keys (add as needed for future components)
# =============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# QDRANT_API_KEY=