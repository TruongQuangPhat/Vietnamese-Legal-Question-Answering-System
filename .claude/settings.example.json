{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LS",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(uv run pytest tests/unit*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run ruff format*)",
      "Bash(uv run mypy src*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(docker compose down -v*)",
      "Bash(printenv*)",
      "Bash(cat .env*)"
    ]
  }
}
