NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# This value is public and embedded at build time.
# Do not put provider, database, Qdrant, session, or Azure secrets in any
# NEXT_PUBLIC_* variable.
#
# Vercel Production must set:
# NEXT_PUBLIC_API_BASE_URL=https://vnlaw-backend-prod-phat.azurewebsites.net
#
# After changing NEXT_PUBLIC_* values in Vercel, redeploy Production.
# Production should never call http://localhost:8000.
# Browser DevTools Network should show:
# https://vnlaw-backend-prod-phat.azurewebsites.net/api/v1/legal-qa/ask
