# ============================================================
# General runtime
# ============================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
APP_ENV=local
CORS_ALLOWED_ORIGINS='["http://localhost:3000","https://vnlaw-qa.vercel.app"]'

# ============================================================
# Qdrant
# ============================================================

QDRANT_URL=https://your-qdrant-cloud-endpoint
QDRANT_COLLECTION=vnlaw_chunks_bgem3_v1_full
QDRANT_API_KEY=

LEGAL_QA_QDRANT_URL=https://your-qdrant-cloud-endpoint
LEGAL_QA_QDRANT_API_KEY=
LEGAL_QA_COLLECTION_NAME=vnlaw_chunks_bgem3_v1_full

# ============================================================
# Legal QA backend
# ============================================================

LEGAL_QA_SERVICE_MODE=real
LEGAL_QA_RETRIEVAL_CONFIG=configs/retrieval/retrieval.yml
LEGAL_QA_CHUNKS_PATH=data/processed/legal_chunks.jsonl

# Public artifact used by hosted/container builds to materialize legal chunks.
LEGAL_QA_CHUNKS_URL=https://huggingface.co/datasets/phattruong1802/vnlaw-qa/resolve/main/legal_chunks/v1/legal_chunks.jsonl
LEGAL_QA_CHUNKS_SHA256=95ff0129915ad4e77306fbdaa2c6eb8c7a7c58730cd21050aec429541416b30c

# Leave blank by default.
# Set to 1 only when intentionally replacing an existing mismatched chunks file.
LEGAL_QA_CHUNKS_OVERWRITE=

LEGAL_QA_LLM_CONFIG=configs/llm/openrouter.yml
LEGAL_QA_DEVICE=cpu

# ============================================================
# Rate limiting
# ============================================================

LEGAL_QA_RATE_LIMIT_ENABLED=true
LEGAL_QA_RATE_LIMIT_REQUESTS=10
LEGAL_QA_RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# Conversation/session storage
# ============================================================

# Local default uses memory to avoid requiring a database.
# Azure production overrides this to postgres.
LEGAL_QA_CONVERSATION_STORE=memory
LEGAL_QA_DATABASE_URL=
LEGAL_QA_ALLOW_DB_TESTS=0
LEGAL_QA_APPLY_DB_SCHEMA=0

# Local default keeps auth disabled.
# Azure production enables auth and requires LEGAL_QA_SESSION_SECRET.
LEGAL_QA_AUTH_ENABLED=false
LEGAL_QA_SESSION_SECRET=
LEGAL_QA_SESSION_HEADER=X-Legal-QA-Session

# ============================================================
# Request timeout / retrieval settings
# ============================================================

LEGAL_QA_ASK_TIMEOUT_SECONDS=90
LEGAL_QA_RETRIEVAL_MODE=hybrid
LEGAL_QA_RETRIEVAL_TIMEOUT_SECONDS=60
LEGAL_QA_EMBEDDING_MODEL_LOAD_TIMEOUT_SECONDS=60
LEGAL_QA_QUERY_EMBEDDING_TIMEOUT_SECONDS=45
LEGAL_QA_QDRANT_TIMEOUT_SECONDS=30
LEGAL_QA_LLM_TIMEOUT_SECONDS=30
LEGAL_QA_MAX_TOP_K=5
LEGAL_QA_RERANKING_ENABLED=false

# Sparse fallback is degraded/emergency fallback only.
# The canonical pipeline remains hybrid BGE-M3 + Qdrant retrieval.
LEGAL_QA_DENSE_RETRIEVAL_FALLBACK_ENABLED=true
LEGAL_QA_DENSE_RETRIEVAL_FALLBACK_MODE=sparse
LEGAL_QA_DENSE_RETRIEVAL_FALLBACK_TIMEOUT_SECONDS=10

# ============================================================
# Warmup/model loading
# ============================================================

# Local default keeps warmup endpoint disabled.
# Azure production enables controlled warmup validation.
LEGAL_QA_EMBEDDING_WARMUP_ENABLED=false
LEGAL_QA_WARMUP_ENDPOINT_ENABLED=false
LEGAL_QA_WARMUP_TIMEOUT_SECONDS=60

# Local/default may be blank.
# Azure production sets this to /models/embedding/bge-m3.
EMBEDDING_MODEL_PATH=

# Optional model override.
LEGAL_QA_MODEL=google/gemini-2.5-flash

# ============================================================
# Provider credentials
# ============================================================

# Optional for private/gated Hugging Face artifacts.
# Keep blank for public artifacts.
HF_TOKEN=

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================================
# Azure production override reference
# ============================================================

# These are documentation comments only.
# Do not copy secrets into Git.
#
# Azure production App Service overrides include:
# APP_ENV=production
# LEGAL_QA_CHUNKS_PATH=/home/data/legal_chunks.jsonl
# LEGAL_QA_CONVERSATION_STORE=postgres
# LEGAL_QA_DATABASE_URL=<secret>
# LEGAL_QA_AUTH_ENABLED=true
# LEGAL_QA_SESSION_SECRET=<secret>
# LEGAL_QA_ALLOW_DB_TESTS=0
# LEGAL_QA_RETRIEVAL_MODE=hybrid
# LEGAL_QA_EMBEDDING_MODEL_LOAD_TIMEOUT_SECONDS=120
# LEGAL_QA_WARMUP_TIMEOUT_SECONDS=180
# LEGAL_QA_WARMUP_ENDPOINT_ENABLED=true
# EMBEDDING_MODEL_PATH=/models/embedding/bge-m3
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
# HF_DATASETS_OFFLINE=1
#
# Azure deployment/GitHub Actions variables belong in GitHub Environments,
# not in local .env files:
# AZURE_CLIENT_ID=<secret>
# AZURE_TENANT_ID=<secret>
# AZURE_SUBSCRIPTION_ID=<secret>
# AZURE_RESOURCE_GROUP=rg-vnlaw-staging
# AZURE_ACR_NAME=vnlawacrphat
# AZURE_ACR_LOGIN_SERVER=vnlawacrphat.azurecr.io
# AZURE_PRODUCTION_WEBAPP_NAME=vnlaw-backend-prod-phat
# AZURE_PRODUCTION_BACKEND_URL=https://vnlaw-backend-prod-phat.azurewebsites.net
